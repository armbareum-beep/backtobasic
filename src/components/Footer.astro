---

<footer class="bg-navy text-white mt-auto">
  <div class="container-wide py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <!-- Brand -->
      <div>
        <div class="flex items-center gap-2 mb-3">
          <div class="w-8 h-8 bg-forest rounded-lg flex items-center justify-center">
            <span class="text-white font-bold text-sm">B²</span>
          </div>
          <span class="font-bold text-lg">Back to Basic</span>
        </div>
        <p class="text-navy-200 text-sm leading-relaxed">
          Veterinary Clinical Nutrition Laboratory<br />
          Kyungpook National University (KNU)
        </p>
        <p class="text-navy-300 text-xs mt-2 italic">
          "Advancing Animal Wellness through Evidence-Based Clinical Nutrition"
        </p>
      </div>

      <!-- Quick Links -->
      <div>
        <h4 class="font-semibold text-sm uppercase tracking-wider text-navy-200 mb-4">Quick Links</h4>
        <ul class="space-y-2 text-sm">
          {[
            { label: 'Professor', href: '/about/professor' },
            { label: 'Philosophy', href: '/about/philosophy' },
            { label: 'Research', href: '/research' },
            { label: 'Careers', href: '/careers' },
            { label: 'Global Collaboration', href: '/collaboration' },
          ].map((link) => (
            <li>
              <a href={link.href} class="text-navy-200 hover:text-white transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h4 class="font-semibold text-sm uppercase tracking-wider text-navy-200 mb-4">Contact</h4>
        <div class="space-y-2 text-sm text-navy-200">
          <p>College of Veterinary Medicine</p>
          <p>Kyungpook National University</p>
          <p>Daegu, Republic of Korea</p>
          <a href="mailto:vetchae@knu.ac.kr" class="block mt-3 text-forest-300 hover:text-white transition-colors">
            vetchae@knu.ac.kr
          </a>
        </div>
      </div>
    </div>

    <div class="border-t border-navy-700 mt-8 pt-6 flex flex-col sm:flex-row items-center justify-between text-xs text-navy-300 gap-2">
      <p>© {new Date().getFullYear()} Back to Basic Lab, KNU. All rights reserved.</p>
      <p>Built with <a href="https://astro.build" class="hover:text-white transition-colors">Astro</a> · Hosted on <a href="https://pages.cloudflare.com" class="hover:text-white transition-colors">Cloudflare Pages</a></p>
    </div>
  </div>
</footer>
