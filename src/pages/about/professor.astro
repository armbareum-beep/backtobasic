---
import BaseLayout from '../../layouts/BaseLayout.astro';

const publications = [
  {
    year: '2024',
    title: 'Gut microbiome composition and its association with body condition in domestic cats with chronic kidney disease',
    journal: 'Journal of Veterinary Internal Medicine',
    doi: '#',
  },
  {
    year: '2023',
    title: 'Serum metabolomic profiling in dogs with hepatocellular carcinoma undergoing nutritional support',
    journal: 'Frontiers in Veterinary Science',
    doi: '#',
  },
  {
    year: '2022',
    title: 'Effects of hydrolyzed protein diet on clinical signs and fecal microbiome in dogs with food-responsive enteropathy',
    journal: 'PLOS ONE',
    doi: '#',
  },
];
---

<BaseLayout
  title="Professor"
  description="Professor profile — Veterinary Clinical Nutrition Laboratory, KNU"
>
  <!-- Page header -->
  <section class="bg-gradient-to-r from-navy to-navy-800 text-white py-16">
    <div class="container-wide">
      <div class="tag mb-3" style="background:rgba(255,255,255,0.1);color:#a7c4e2;">Laboratory Introduction</div>
      <h1 class="text-4xl font-bold mb-2">Prof. Hyungkyu Choi (최형규)</h1>
      <p class="text-navy-200">Meet the researcher behind Back to Basic Lab</p>
    </div>
  </section>

  <!-- Profile -->
  <section class="section-padding">
    <div class="container-wide">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
        <!-- Photo + quick info -->
        <div class="lg:col-span-1">
          <div class="bg-slate-100 rounded-2xl aspect-square flex items-center justify-center mb-6 overflow-hidden">
            <img src="/images/professor.jpg" alt="Prof. Hyungkyu Choi" class="w-full h-full object-cover" />
          </div>

          <!-- Quick facts -->
          <div class="space-y-3">
            {[
              { icon: '🎓', label: 'PhD', value: 'Seoul National University (SNU)' },
              { icon: '🏥', label: 'Clinical Experience', value: '13 years (Internal Medicine)' },
              { icon: '🏛️', label: 'Current Position', value: 'Professor, KNU College of Veterinary Medicine' },
              { icon: '🔬', label: 'Specialty', value: 'Veterinary Clinical Nutrition & Internal Medicine' },
            ].map(({ icon, label, value }) => (
              <div class="flex gap-3 p-3 bg-slate-50 rounded-xl">
                <span class="text-lg flex-shrink-0">{icon}</span>
                <div>
                  <p class="text-xs font-semibold text-slate-400 uppercase tracking-wide">{label}</p>
                  <p class="text-sm text-slate-700 font-medium">{value}</p>
                </div>
              </div>
            ))}
          </div>

          <!-- External links -->
          <div class="mt-6 flex flex-col gap-2">
            <a href="https://scholar.google.com/citations?user=Uuu5MkwAAAAJ&hl=en" target="_blank" rel="noopener" class="flex items-center gap-2 text-sm text-forest hover:text-forest-700 font-medium">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
              Google Scholar
            </a>
            <a href="mailto:vetchae@knu.ac.kr" class="flex items-center gap-2 text-sm text-forest hover:text-forest-700 font-medium">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
              vetchae@knu.ac.kr
            </a>
          </div>
        </div>

        <!-- Bio -->
        <div class="lg:col-span-2 space-y-8">
          <div>
            <h2 class="text-2xl font-bold text-navy mb-4">Biography</h2>
            <div class="prose text-slate-600 leading-relaxed space-y-4">
              <p>
                Professor Hyungkyu Choi (최형규) leads the Veterinary Clinical Nutrition Laboratory at Kyungpook National University (KNU),
                College of Veterinary Medicine. Having completed a PhD at Seoul National University (SNU) and accumulated
                over 13 years of clinical experience in veterinary internal medicine, the lab bridges deep clinical insight
                with frontier nutritional science.
              </p>
              <p>
                The laboratory operates under the guiding principle of <strong class="text-navy">"Back to the Basic"</strong> —
                the belief that rigorous, patient-centered assessment (BCS, MCS) must underpin any nutritional intervention,
                no matter how advanced the technology applied.
              </p>
              <p>
                Current research spans gut microbiome profiling via NGS, metabolomic biomarker discovery using LC-MS/HPLC,
                and clinical nutrition trials for chronic kidney disease, oncology, and food allergy patients at the
                University VMTH.
              </p>
            </div>
          </div>

          <!-- Education & Career timeline -->
          <div>
            <h2 class="text-2xl font-bold text-navy mb-4">Education & Career</h2>
            <div class="relative pl-6 space-y-6 border-l-2 border-slate-200">
              {[
                {
                  period: 'Current',
                  role: 'Professor',
                  org: 'Kyungpook National University (KNU), College of Veterinary Medicine',
                  highlight: true,
                },
                {
                  period: '~13 years',
                  role: 'Clinical Veterinarian — Internal Medicine',
                  org: 'Veterinary Medical Teaching Hospital (VMTH)',
                  highlight: false,
                },
                {
                  period: 'PhD',
                  role: 'Doctor of Philosophy in Veterinary Medicine',
                  org: 'Seoul National University (SNU)',
                  highlight: false,
                },
              ].map(({ period, role, org, highlight }) => (
                <div class="relative">
                  <div class={`absolute -left-[29px] w-4 h-4 rounded-full border-2 border-white ${highlight ? 'bg-forest' : 'bg-slate-300'}`}></div>
                  <p class="text-xs font-bold text-forest uppercase tracking-wider mb-0.5">{period}</p>
                  <p class="font-semibold text-navy">{role}</p>
                  <p class="text-sm text-slate-500">{org}</p>
                </div>
              ))}
            </div>
          </div>

          <!-- Selected publications -->
          <div>
            <h2 class="text-2xl font-bold text-navy mb-4">Selected Publications</h2>
            <div class="space-y-4">
              {publications.map(({ year, title, journal, doi }) => (
                <div class="p-4 bg-slate-50 rounded-xl border border-slate-200 hover:border-navy transition-colors">
                  <div class="flex items-start justify-between gap-4">
                    <div>
                      <span class="tag mb-2">{year}</span>
                      <p class="text-sm font-medium text-slate-800 leading-snug mb-1">{title}</p>
                      <p class="text-xs text-slate-400 italic">{journal}</p>
                    </div>
                    <a href={doi} class="flex-shrink-0 text-forest hover:text-forest-700">
                      <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                      </svg>
                    </a>
                  </div>
                </div>
              ))}
            </div>
            <a href="https://scholar.google.com/citations?user=Uuu5MkwAAAAJ&hl=en" target="_blank" rel="noopener" class="inline-flex items-center gap-1 mt-4 text-sm text-forest font-medium hover:text-forest-700">
              View all publications on Google Scholar
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
