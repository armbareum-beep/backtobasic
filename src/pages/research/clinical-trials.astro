---
import BaseLayout from '../../layouts/BaseLayout.astro';

const trials = [
  {
    condition: 'Chronic Kidney Disease (CKD) & Metabolic Balance',
    icon: '🫘',
    stage: 'Ongoing',
    color: 'border-forest-200 bg-forest-50',
    badgeColor: 'bg-forest-100 text-forest-700',
    objectives: [
      'Evaluate phosphorus-restricted diet efficacy across IRIS CKD stages 2–4 to reduce systemic uremic load.',
      'Monitor SDMA, creatinine, and UPC ratio as biomarkers for holistic renal health and nutritional response.',
      'Compare protein source (plant vs. animal) effects on uremic toxin modulation and gut-kidney axis health.',
    ],
  },
  {
    condition: 'Oncology & Cancer Cachexia: Supportive Integrative Care',
    icon: '🎗️',
    stage: 'Ongoing',
    color: 'border-navy-200 bg-navy-50',
    badgeColor: 'bg-navy-100 text-navy-700',
    objectives: [
      'Assess muscle mass preservation (MCS) and metabolic stability in tumor-bearing dogs through precision nutrition.',
      'Evaluate the role of omega-3 fatty acids (EPA/DHA) in modulating inflammatory cytokine profiles and improving quality of life.',
      'Develop comprehensive cachexia grading and multimodal nutritional intervention criteria for veterinary oncology.',
    ],
  },
  {
    condition: 'Food Allergy & Gut Health Restoration',
    icon: '🌾',
    stage: 'Enrolling',
    color: 'border-yellow-200 bg-yellow-50',
    badgeColor: 'bg-yellow-100 text-yellow-700',
    objectives: [
      'Conduct prospective elimination diet trials focusing on immune system stabilization through novel and hydrolyzed proteins.',
      'Track gut microbiome shifts and mucosal barrier integrity during dietary elimination and rechallenge phases.',
      'Establish breed-specific antigen sensitivity profiles to provide personalized, allergen-free lifestyle recommendations.',
    ],
  },
];
---

<BaseLayout title="Integrative Medicine" description="Integrative veterinary medicine — clinical nutrition, disease management, and evidence-based care at Back to Basic Lab">
  <section class="bg-gradient-to-r from-navy to-navy-800 text-white py-16">
    <div class="container-wide">
      <a href="/research" class="text-navy-300 text-sm hover:text-white mb-4 inline-flex items-center gap-1">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" /></svg>
        Research
      </a>
      <div class="tag mb-3" style="background:rgba(255,255,255,0.1);color:#a7c4e2;">VMTH · CKD · Oncology · Allergy</div>
      <h1 class="text-4xl font-bold mb-2">Integrative Medicine</h1>
      <p class="text-navy-200">An integrative approach to veterinary patient care at the KNU Veterinary Medical Teaching Hospital</p>
    </div>
  </section>

  <section class="section-padding">
    <div class="container-wide max-w-4xl">
      <div class="prose max-w-none mb-12">
        <div class="tag mb-4">Overview</div>
        <h2 class="text-2xl font-bold text-navy mb-4">An Integrative Approach to Veterinary Patient Care</h2>
        <p class="text-slate-600 leading-relaxed mb-4">
          Our clinical trials program operates at the intersection of conventional veterinary medicine and evidence-based
          clinical nutrition. At the KNU Veterinary Medical Teaching Hospital (VMTH), we advocate for an integrative
          management strategy that views the patient as a whole.
        </p>
        <p class="text-slate-600 leading-relaxed">
          By combining cutting-edge molecular diagnostics with a "Back to the Basics" philosophy, we move beyond simple
          symptom management. We focus on restoring systemic balance through personalized nutritional therapy, ensuring that
          dietary interventions are evaluated with the same clinical rigor as pharmacological treatments.
        </p>
      </div>

      <!-- Active trials -->
      <div class="space-y-6 mb-12">
        <h2 class="text-2xl font-bold text-navy">Active Research Trials: Integrative Disease Management</h2>
        {trials.map(({ condition, icon, stage, color, badgeColor, objectives }) => (
          <div class={`rounded-2xl border-2 p-6 ${color}`}>
            <div class="flex items-start justify-between gap-4 mb-4">
              <div class="flex items-center gap-3">
                <span class="text-3xl">{icon}</span>
                <h3 class="text-xl font-bold text-navy">{condition}</h3>
              </div>
              <span class={`text-xs font-bold px-3 py-1 rounded-full ${badgeColor}`}>{stage}</span>
            </div>
            <ul class="space-y-2">
              {objectives.map((obj) => (
                <li class="flex items-start gap-2 text-sm text-slate-600">
                  <span class="text-forest mt-0.5 flex-shrink-0">›</span>
                  {obj}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>

      <!-- Guidelines output -->
      <div class="bg-navy text-white rounded-2xl p-8 mb-12">
        <h2 class="text-2xl font-bold mb-4">Integrative Clinical Guideline Development</h2>
        <p class="text-navy-200 text-sm leading-relaxed mb-6">
          Findings from our trials are synthesized into evidence-based guidelines that empower veterinary
          practitioners to implement integrative, species-specific care.
        </p>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
          {[
            { icon: '📋', label: 'Integrative CKD Nutrition Guidelines', status: 'In preparation' },
            { icon: '🎗️', label: 'Oncology Supportive Care Protocol', status: 'In preparation' },
            { icon: '🌾', label: 'Holistic Food Allergy Elimination Guide', status: 'Coming soon' },
          ].map(({ icon, label, status }) => (
            <div class="bg-white/10 rounded-xl p-4 text-center">
              <div class="text-2xl mb-2">{icon}</div>
              <p class="font-medium text-sm mb-1">{label}</p>
              <p class="text-xs text-navy-300">{status}</p>
            </div>
          ))}
        </div>
      </div>

      <div class="flex flex-wrap gap-4">
        <a href="/research/metabolomics" class="btn-outline">← Metabolomics</a>
        <a href="/careers" class="btn-primary bg-forest hover:bg-forest-600">Career Pathways →</a>
      </div>
    </div>
  </section>
</BaseLayout>
