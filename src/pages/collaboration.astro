---
import BaseLayout from '../layouts/BaseLayout.astro';

const members = [
  {
    category: 'Professor',
    people: [
      { name: 'Hyung-Kyu Chae (채형규)', role: 'Lab Director', photo: '/images/members/chae-hyungkyu.jpg' },
    ],
  },
  {
    category: 'Ph.D. Student',
    people: [
      { name: 'Changtae Kim (김창태)', role: 'Ph.D. Candidate', photo: '/images/members/kim-changtae.jpg' },
    ],
  },
  {
    category: 'M.S. Students',
    people: [
      { name: 'Minji Kim (김민지)', role: 'M.S. Student', photo: '/images/members/kim-minji.jpg' },
      { name: 'Jeonghyeon Kwon (권정현)', role: 'M.S. Student', photo: '/images/members/kwon-jeonghyeon.jpg' },
      { name: 'Byeongwoon Kang (강병운)', role: 'M.S. Student', photo: '/images/members/kang-byeongwoon.png' },
      { name: 'Somi Jang (장솜이)', role: 'M.S. Student', photo: '/images/members/jang-somi.jpg' },
      { name: 'Woocheol Lee (이우철)', role: 'M.S. Student', photo: '/images/members/lee-woocheol.jpg' },
    ],
  },
];

const photos = [
  { src: '/images/collab-01.jpg', label: 'Lab Activity' },
  { src: '/images/collab-02.jpg', label: 'Collaboration' },
  { src: '/images/collab-03.jpg', label: 'Conference' },
  { src: '/images/collab-04.jpg', label: 'Research Meeting' },
  { src: '/images/collab-05.jpg', label: 'Lab Exchange' },
  { src: '/images/collab-06.jpg', label: 'Workshop' },
  { src: '/images/collab-07.jpg', label: 'Poster Session' },
  { src: '/images/collab-08.jpg', label: 'International Visit' },
];
---

<BaseLayout title="Members" description="Lab members — Veterinary Clinical Nutrition Laboratory, KNU">
  <section class="bg-gradient-to-r from-navy to-navy-800 text-white py-16">
    <div class="container-wide">
      <div class="tag mb-3" style="background:rgba(255,255,255,0.1);color:#a7c4e2;">Our Team</div>
      <h1 class="text-4xl font-bold mb-2">Lab Members</h1>
      <p class="text-navy-200 max-w-xl">
        Meet the researchers behind the Veterinary Clinical Nutrition Laboratory at KNU.
      </p>
    </div>
  </section>

  <!-- Members -->
  <section class="section-padding">
    <div class="container-wide">
      {members.map(({ category, people }) => (
        <div class="mb-12">
          <div class="tag mb-4">{category}</div>
          <div class={`grid gap-6 ${people.length === 1 ? 'grid-cols-1 max-w-sm' : 'grid-cols-1 sm:grid-cols-2 md:grid-cols-3'}`}>
            {people.map(({ name, role, photo }) => (
              <div class="bg-white border border-slate-200 rounded-2xl p-6 hover:border-navy hover:shadow-md transition-all text-center">
                <div class="w-24 h-24 mx-auto mb-4 rounded-full overflow-hidden bg-slate-100 flex items-center justify-center">
                  {photo ? (
                    <img src={photo} alt={name} class="w-full h-full object-cover" />
                  ) : (
                    <svg class="w-10 h-10 text-slate-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" />
                    </svg>
                  )}
                </div>
                <h3 class="font-bold text-navy mb-1">{name}</h3>
                <p class="text-sm text-slate-400">{role}</p>
              </div>
            ))}
          </div>
        </div>
      ))}

      <!-- Photo gallery -->
      <div class="mt-16">
        <div class="tag mb-3">Gallery</div>
        <h2 class="text-3xl font-bold text-navy mb-6">Lab Life</h2>
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
          {photos.map(({ src, label }) => (
            <div class="aspect-square rounded-xl overflow-hidden border border-slate-200">
              <img src={src} alt={label} class="w-full h-full object-cover hover:scale-105 transition-transform duration-300" />
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Join us CTA -->
  <section class="section-padding bg-navy text-white">
    <div class="container-wide text-center max-w-2xl mx-auto">
      <h2 class="text-3xl font-bold mb-4">Join Our Lab</h2>
      <p class="text-navy-200 mb-8">
        We welcome motivated students and researchers who share our passion for evidence-based veterinary clinical nutrition.
      </p>
      <div class="flex flex-wrap gap-4 justify-center">
        <a href="mailto:vetchae@knu.ac.kr" class="btn-primary bg-forest hover:bg-forest-600">
          Contact Us
        </a>
        <a href="/careers" class="inline-flex items-center gap-2 border border-white/30 text-white px-6 py-3 rounded-lg font-medium hover:bg-white/10 transition-colors">
          Career Pathways
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
